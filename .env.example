# Upstash Redis REST credentials
# Get these from https://console.upstash.com after creating a database
# Set them in Vercel project settings → Environment Variables for deploys,
# and copy this file to `.env` for local development with `vercel dev`.

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Buttondown API credentials
# Get these from https://buttondown.email/settings/programming
BUTTONDOWN_API_KEY=
